generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  email          String          @unique
  passwordHash   String          @map("password_hash")
  roles          String[]        @default(["user"])
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  orders         Order[]
  stockMovements StockMovement[]

  @@index([email])
  @@map("users")
}

model Product {
  id              String          @id @default(uuid()) @db.Uuid
  sku             String          @unique
  name            String
  brand           String
  model           String
  category        String          @default("phone")
  categoryId      String?         @map("category_id") @db.Uuid
  supplierId      String?         @map("supplier_id") @db.Uuid
  quantityPerUnit String?         @map("quantity_per_unit")
  price           Decimal         @db.Decimal(12, 2)
  unitsInStock    Int             @default(0) @map("units_in_stock")
  unitsOnOrder    Int             @default(0) @map("units_on_order")
  reorderLevel    Int             @default(0) @map("reorder_level")
  discontinued    Boolean         @default(false)
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  supplier        Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  categoryRef     Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventory       InventoryItem?
  orderItems      OrderItem[]
  movements       StockMovement[]

  @@index([brand])
  @@index([model])
  @@index([categoryId])
  @@index([supplierId])
  @@map("products")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  picture     String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  products    Product[]

  @@map("categories")
}

model Supplier {
  id           String    @id @default(uuid()) @db.Uuid
  companyName  String    @map("company_name")
  contactName  String?   @map("contact_name")
  contactTitle String?   @map("contact_title")
  address      String?
  city         String?
  region       String?
  postalCode   String?   @map("postal_code")
  country      String?
  phone        String?
  fax          String?
  homepage     String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  products     Product[]

  @@index([companyName])
  @@map("suppliers")
}

model InventoryItem {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @unique @map("product_id") @db.Uuid
  quantity  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory_items")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  orders    Order[]

  @@index([phone])
  @@index([email])
  @@map("customers")
}

model Order {
  id             String      @id @default(uuid()) @db.Uuid
  customerId     String?     @map("customer_id") @db.Uuid
  employeeId     String?     @map("employee_id") @db.Uuid
  createdById    String      @map("created_by_id") @db.Uuid
  deliveryCompanyId String?   @map("delivery_company_id") @db.Uuid
  status         String      @default("pending")
  orderDate      DateTime    @default(now()) @map("order_date") @db.Timestamptz(6)
  requiredDate   DateTime?   @map("required_date") @db.Timestamptz(6)
  shippedDate    DateTime?   @map("shipped_date") @db.Timestamptz(6)
  freight        Decimal     @default(0) @db.Decimal(12, 2)
  shipName       String?     @map("ship_name")
  shipAddress    String?     @map("ship_address")
  shipCity       String?     @map("ship_city")
  shipRegion     String?     @map("ship_region")
  shipPostalCode String?     @map("ship_postal_code")
  shipCountry    String?     @map("ship_country")
  totalAmount    Decimal     @default(0) @map("total_amount") @db.Decimal(12, 2)
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer       Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  employee       Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  createdBy      User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  deliveryCompany DeliveryCompany? @relation(fields: [deliveryCompanyId], references: [id], onDelete: SetNull)
  items          OrderItem[]

  @@index([customerId])
  @@index([employeeId])
  @@index([createdById])
  @@index([deliveryCompanyId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @map("order_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  discount  Decimal @default(0) @db.Decimal(5, 2)
  lineTotal Decimal @map("line_total") @db.Decimal(12, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model StockMovement {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  quantity  Int
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([userId])
  @@index([type])
  @@map("stock_movements")
}

model DeliveryCompany {
  id          String   @id @default(uuid()) @db.Uuid
  companyName String   @map("company_name")
  phone       String?
  trackingUrl String?  @map("tracking_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  orders      Order[]

  @@index([companyName])
  @@map("delivery_companies")
}

model Employee {
  id              String              @id @default(uuid()) @db.Uuid
  lastName        String              @map("last_name")
  firstName       String              @map("first_name")
  title           String?
  titleOfCourtesy String?             @map("title_of_courtesy")
  birthDate       DateTime?           @map("birth_date") @db.Timestamptz(6)
  hireDate        DateTime?           @map("hire_date") @db.Timestamptz(6)
  address         String?
  city            String?
  region          String?
  postalCode      String?             @map("postal_code")
  country         String?
  homePhone       String?             @map("home_phone")
  extension       String?
  photo           String?
  notes           String?
  reportsToId     String?             @map("reports_to_id") @db.Uuid
  photoPath       String?             @map("photo_path")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  reportsTo       Employee?           @relation("EmployeeReports", fields: [reportsToId], references: [id], onDelete: SetNull)
  directReports   Employee[]          @relation("EmployeeReports")
  orders          Order[]

  @@index([lastName])
  @@index([reportsToId])
  @@map("employees")
}
